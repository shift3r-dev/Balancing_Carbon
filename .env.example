# AI is disabled by default. Keep provider credentials server-side only.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=""

# SUPABASE_URL: The API URL of your Supabase project (found in Project Settings -> API)
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: The public anonymous key for Supabase (found in Project Settings -> API)
SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: The service_role key bypasses RLS (found in Project Settings -> API)
# Use this server-side in server.ts/supabase.ts to authenticate operations
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional runtime foundation settings.
PORT="3000"
LOG_LEVEL="info"
SUPABASE_STORAGE_BUCKET="evidence"
EMAIL_FROM=""
AI_ENABLED="false"
AI_PROVIDER="gemini"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3:8b"
OLLAMA_CONTEXT_LENGTH="8192"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_API_KEY=""
AI_TIMEOUT_MS="120000"
AI_ALLOW_EXTERNAL="false"
BILLING_PROVIDER=""
ERP_BASE_URL=""
