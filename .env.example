# AI integration is intentionally disabled in Phase 1. Do not add an AI key yet.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The API URL of your Supabase project (found in Project Settings -> API)
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: The public anonymous key for Supabase (found in Project Settings -> API)
SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: The service_role key bypasses RLS (found in Project Settings -> API)
# Use this server-side in server.ts/supabase.ts to authenticate operations
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional runtime foundation settings. These do not enable billing, AI, or ERP integrations.
PORT="3000"
LOG_LEVEL="info"
SUPABASE_STORAGE_BUCKET=""
EMAIL_FROM=""
AI_PROVIDER=""
BILLING_PROVIDER=""
ERP_BASE_URL=""
