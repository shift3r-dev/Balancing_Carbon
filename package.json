{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:carbon": "tsx --test server/carbonAccounting.test.ts",
    "test:phase2": "tsx --test server/phase2CarbonIntelligence.test.ts",
    "test:reporting": "tsx --test server/reportingEngine.test.ts",
    "test:metadata": "tsx --test server/metadataEngine.test.ts",
    "test:data": "tsx --test server/dataIngestion.test.ts",
    "test:ai": "tsx --test server/ai/ollamaProvider.test.ts",
    "test:documents": "tsx --test server/documentExtraction.test.ts",
    "test:studio": "tsx --test server/reportStudioEngine.test.ts",
    "test:analytics": "tsx --test server/analyticsFormula.test.ts",
    "test:sustainability": "tsx --test server/sustainabilityIntelligence.test.ts",
    "test:workflow": "tsx --test server/workflowRules.test.ts",
    "test:portal": "tsx --test server/publicPortalEngine.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.2.0",
    "@types/pdfkit": "^0.17.6",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
